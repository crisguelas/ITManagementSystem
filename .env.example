# ═══════════════════════════════════════════════════════════════
# IT Management System — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# DATABASE
# ───────────────────────────────────────────────────────────────
# For Neon (cloud PostgreSQL):
# DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"
#
# For self-hosted PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/itms"
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# ───────────────────────────────────────────────────────────────
# AUTHENTICATION (NextAuth.js)
# ───────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-random-secret-key"

# Application URL (change for production)
NEXTAUTH_URL="http://localhost:3000"

# ───────────────────────────────────────────────────────────────
# ASSET TAGS (optional — server only)
# ───────────────────────────────────────────────────────────────
# Global prefix for new tags: {ASSET_TAG_PREFIX}-{CATEGORY_PREFIX}-{NUMBER}
# Letters/numbers only, max 8 chars. Default if unset: AST
# ASSET_TAG_PREFIX="AST"

# ───────────────────────────────────────────────────────────────
# SEED (required for `npm run db:seed` — first admin user)
# ───────────────────────────────────────────────────────────────
# Use a strong password; never commit real values to git.
SEED_ADMIN_EMAIL="admin@example.local"
SEED_ADMIN_PASSWORD=""
