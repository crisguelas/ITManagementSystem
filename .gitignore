# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real secrets (use .env.example as a template only)
.env*
!.env.example

# local-only folders — keep documentation assets and backups off GitHub
docs/
backups/

# local backup artifacts — schema/data snapshots must remain local
backups/db-data-backup-*.json
backups/schema-prisma-backup-*.prisma
backups/db-full-backup-*.sql

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
